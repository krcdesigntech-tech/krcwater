# === 수집(ingestion) 측 시크릿 — 복사해서 .env 로 저장 / Actions secrets 로 등록 ===
# Supabase 프로젝트 Settings > API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=         # service_role 키 (쓰기 권한, 절대 공개 금지)

# Google AI Studio (Gemini) — 임베딩 text-embedding-004 (무료)
GEMINI_API_KEY=

# 스크랩 대상 litt.ly 페이지
LITTLY_URL=https://litt.ly/krc.wrmo

# === 웹(Vercel) 측 — web/.env.local 또는 Vercel 환경변수 ===
# 브라우저 노출 가능(anon, RLS 읽기 전용)
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...
# 서버 전용(/api/ask 서버리스 함수에서만 사용 — 절대 PUBLIC_ 접두어 금지)
OPENROUTER_API_KEY=sk-or-...
# GEMINI_API_KEY 는 위와 동일 키 재사용
